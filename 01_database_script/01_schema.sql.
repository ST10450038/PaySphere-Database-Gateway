-- CLEAR EXISTING TABLES TO ENSURE IDEMPOTENCY (Run-clean scripts)
BEGIN
    FOR t IN (SELECT table_name FROM user_tables WHERE table_name IN ('AUDIT_LOGS', 'TRANSACTIONS', 'ACCOUNTS', 'USERS')) LOOP
        EXECUTE IMMEDIATE 'DROP TABLE ' || t.table_name || ' CASCADE CONSTRAINTS';
    END LOOP;
END;
/

-- ==========================================
-- 1. USERS TABLE
-- Stores profile identities with unique email constraints.
-- ==========================================
CREATE TABLE USERS (
    user_id       NUMBER GENERATED BY DEFAULT AS IDENTITY (START WITH 1000 INCREMENT BY 1),
    first_name    VARCHAR2(50) NOT NULL,
    last_name     VARCHAR2(50) NOT NULL,
    email         VARCHAR2(100) NOT NULL,
    phone_number  VARCHAR2(15),
    created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    -- Constraints
    CONSTRAINT pk_users PRIMARY KEY (user_id),
    CONSTRAINT uq_user_email UNIQUE (email)
);

-- ==========================================
-- 2. ACCOUNTS TABLE
-- Holds financial positioning. Enforces transactional business rules.
-- ==========================================
CREATE TABLE ACCOUNTS (
    account_id    NUMBER GENERATED BY DEFAULT AS IDENTITY (START WITH 5000 INCREMENT BY 1),
    user_id       NUMBER NOT NULL,
    account_type  VARCHAR2(20) NOT NULL,
    balance       NUMBER(15, 2) DEFAULT 0.00 NOT NULL,
    currency      VARCHAR2(3) DEFAULT 'ZAR' NOT NULL,
    status        VARCHAR2(15) DEFAULT 'ACTIVE' NOT NULL,
    updated_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    -- Constraints
    CONSTRAINT pk_accounts PRIMARY KEY (account_id),
    CONSTRAINT fk_accounts_user FOREIGN KEY (user_id) REFERENCES USERS(user_id) ON DELETE CASCADE,
    CONSTRAINT chk_account_type CHECK (account_type IN ('CHECKING', 'SAVINGS', 'CREDIT')),
    CONSTRAINT chk_account_status CHECK (status IN ('ACTIVE', 'SUSPENDED', 'FROZEN')),
    CONSTRAINT chk_positive_balance CHECK (balance >= 0.00) -- Prevents overdraft processing outside allowed credit lines
);

-- ==========================================
-- 3. TRANSACTIONS TABLE
-- Immutable double-entry ledger capturing payment distributions.
-- ==========================================
CREATE TABLE TRANSACTIONS (
    transaction_id    NUMBER GENERATED BY DEFAULT AS IDENTITY (START WITH 90000 INCREMENT BY 1),
    source_acc_id     NUMBER NOT NULL,
    dest_acc_id       NUMBER NOT NULL,
    amount            NUMBER(15, 2) NOT NULL,
    transaction_type  VARCHAR2(20) NOT NULL,
    status            VARCHAR2(15) DEFAULT 'PENDING' NOT NULL,
    reference_desc    VARCHAR2(100),
    timestamp         TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    -- Constraints
    CONSTRAINT pk_transactions PRIMARY KEY (transaction_id),
    CONSTRAINT fk_tx_source FOREIGN KEY (source_acc_id) REFERENCES ACCOUNTS(account_id),
    CONSTRAINT fk_tx_dest FOREIGN KEY (dest_acc_id) REFERENCES ACCOUNTS(account_id),
    CONSTRAINT chk_positive_amount CHECK (amount > 0.00),
    CONSTRAINT chk_tx_type CHECK (transaction_type IN ('TRANSFER', 'DEPOSIT', 'WITHDRAWAL', 'BILL_PAYMENT')),
    CONSTRAINT chk_tx_status CHECK (status IN ('PENDING', 'SUCCESSFUL', 'FAILED'))
);

-- ==========================================
-- 4. AUDIT_LOGS TABLE
-- Security compliance table documenting exact internal system mutations.
-- ==========================================
CREATE TABLE AUDIT_LOGS (
    log_id         NUMBER GENERATED BY DEFAULT AS IDENTITY (START WITH 1 INCREMENT BY 1),
    table_name     VARCHAR2(30) NOT NULL,
    operation_type VARCHAR2(10) NOT NULL,
    record_id      NUMBER NOT NULL,
    old_value      CLOB, -- For detailed state data
    new_value      CLOB, -- For detailed state data
    changed_by     VARCHAR2(50) DEFAULT USER NOT NULL,
    timestamp      TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    -- Constraints
    CONSTRAINT pk_audit_logs PRIMARY KEY (log_id),
    CONSTRAINT chk_op_type CHECK (operation_type IN ('INSERT', 'UPDATE', 'DELETE'))
);

-- Add comments for data dictionary visibility (Signs of a mature developer)
COMMENT ON COLUMN ACCOUNTS.balance IS 'Maintains current cleared funds. Enforced by chk_positive_balance constraint.';
COMMENT ON COLUMN TRANSACTIONS.transaction_type IS 'Tracks systemic origin of funds allocation.';
